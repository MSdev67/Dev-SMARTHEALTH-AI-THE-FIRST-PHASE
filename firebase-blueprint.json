{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and preferences.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "language": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "role"]
    },
    "SymptomLog": {
      "title": "Symptom Analysis",
      "description": "History of symptoms and AI-predicted diagnoses.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "symptoms": { "type": "array", "items": { "type": "string" } },
        "prediction": { "type": "string" },
        "confidence": { "type": "number" },
        "analysis": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Appointment": {
      "title": "Medical Appointment",
      "description": "Scheduled consultation between patient and doctor.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "type": { "type": "string", "enum": ["online", "in-person"] },
        "hasPrescription": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Prescription": {
      "title": "Digital Prescription",
      "description": "Secure, doctor-issued medical prescription.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "appointmentId": { "type": "string" },
        "medications": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "medications"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "Real-time communication message.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles restricted to owner or admins."
    },
    "/symptomLogs/{logId}": {
      "schema": "SymptomLog",
      "description": "Individual symptom logs."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Consultation bookings."
    },
    "/prescriptions/{prescriptionId}": {
      "schema": "Prescription",
      "description": "Secure digital prescriptions issued by clinical professionals."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat thread."
    }
  }
}
